{
 "autoname": "field:shift_name",
 "creation": "2024-01-01 00:00:00",
 "doctype": "DocType",
 "engine": "InnoDB",
 "field_order": [
  "shift_name","color","column_break_1","company","is_active",
  "section_timing","start_time","end_time","is_night_shift",
  "section_hours","full_day_hours","half_day_hours","standard_working_hours",
  "section_calc","working_hours_method","missing_checkin_action",
  "section_grace","late_entry_grace","early_exit_grace",
  "section_overtime","enable_overtime","overtime_calculation_method",
  "overtime_threshold_minutes","column_break_ot","overtime_rate_multiplier",
  "max_overtime_hours_per_day",
  "section_notes","description"
 ],
 "fields": [
  {"fieldname":"shift_name","fieldtype":"Data","label":"Shift Name","reqd":1,"unique":1,"in_list_view":1},
  {"fieldname":"color","fieldtype":"Color","label":"Color","default":"#2490ef"},
  {"fieldname":"column_break_1","fieldtype":"Column Break"},
  {"fieldname":"company","fieldtype":"Link","label":"Company","options":"Company","reqd":1},
  {"fieldname":"is_active","fieldtype":"Check","label":"Active","default":"1","in_list_view":1},
  {"fieldname":"section_timing","fieldtype":"Section Break","label":"Timing"},
  {"fieldname":"start_time","fieldtype":"Time","label":"Start Time","reqd":1,"in_list_view":1},
  {"fieldname":"end_time","fieldtype":"Time","label":"End Time","reqd":1,"in_list_view":1},
  {"fieldname":"is_night_shift","fieldtype":"Check","label":"Night Shift (crosses midnight)","default":"0"},
  {"fieldname":"section_hours","fieldtype":"Section Break","label":"Hour Thresholds"},
  {"fieldname":"full_day_hours","fieldtype":"Float","label":"Full Day Minimum Hours","default":"8","reqd":1},
  {"fieldname":"half_day_hours","fieldtype":"Float","label":"Half Day Minimum Hours","default":"4","reqd":1},
  {"fieldname":"standard_working_hours","fieldtype":"Float","label":"Standard Daily Hours (for absent calc)","default":"8","reqd":1},
  {"fieldname":"section_calc","fieldtype":"Section Break","label":"Calculation Rules"},
  {"fieldname":"working_hours_method","fieldtype":"Select","label":"Working Hours Method",
   "options":"First IN - Last OUT\nActual Pairs (IN-OUT)","default":"First IN - Last OUT"},
  {"fieldname":"missing_checkin_action","fieldtype":"Select","label":"Missing Check-In/Out Action",
   "options":"Mark as Invalid\nMark as Present\nRequire Manual Review","default":"Mark as Invalid"},
  {"fieldname":"section_grace","fieldtype":"Section Break","label":"Grace Periods"},
  {"fieldname":"late_entry_grace","fieldtype":"Int","label":"Late Entry Grace (minutes)","default":"0"},
  {"fieldname":"early_exit_grace","fieldtype":"Int","label":"Early Exit Grace (minutes)","default":"0"},
  {"fieldname":"section_overtime","fieldtype":"Section Break","label":"Overtime Management"},
  {"fieldname":"enable_overtime","fieldtype":"Check","label":"Enable Overtime Calculation","default":"0"},
  {"fieldname":"overtime_calculation_method","fieldtype":"Select","label":"Overtime Calculation Method",
   "options":"After Standard Hours\nAfter Shift End Time\nOT Punches Only","default":"After Standard Hours",
   "depends_on":"eval:doc.enable_overtime",
   "description":"After Standard Hours: any working hours beyond Standard Daily Hours count as OT.\nAfter Shift End Time: time worked past the shift's End Time counts as OT.\nOT Punches Only: only explicit device OT In/OT Out punches (code 4/5) are counted as OT."},
  {"fieldname":"overtime_threshold_minutes","fieldtype":"Int","label":"OT Threshold (minutes)","default":"0",
   "depends_on":"eval:doc.enable_overtime",
   "description":"Minimum extra minutes worked before overtime is counted (avoids paying OT for a few minutes of rounding)."},
  {"fieldname":"column_break_ot","fieldtype":"Column Break"},
  {"fieldname":"overtime_rate_multiplier","fieldtype":"Float","label":"Overtime Rate Multiplier","default":"1.5",
   "depends_on":"eval:doc.enable_overtime",
   "description":"Used for reference only — actual OT pay rules are configured in Payroll."},
  {"fieldname":"max_overtime_hours_per_day","fieldtype":"Float","label":"Max OT Hours per Day","default":"0",
   "depends_on":"eval:doc.enable_overtime",
   "description":"0 = no cap. Overtime hours beyond this cap are recorded but not paid."},
  {"fieldname":"section_notes","fieldtype":"Section Break","label":"Notes"},
  {"fieldname":"description","fieldtype":"Small Text","label":"Description"}
 ],
 "links": [],
